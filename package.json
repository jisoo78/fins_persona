{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "api": "tsx server/index.ts",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "rag:prepare:holdout": "python3 scripts/prepare_holdout_dataset.py",
    "rag:index:bge-m3": "python3 scripts/build_bge_m3_index.py",
    "rag:index:bge-m3:train": "RAG_ARCHIVE_DIR=archive_eval/train python3 scripts/build_bge_m3_index.py",
    "rag:evaluate:keyword": "tsx server/generateGeneralRagEvaluation.ts",
    "rag:evaluate:vector": "RAG_RETRIEVAL=vector tsx server/generateGeneralRagEvaluation.ts",
    "rag:evaluate:vector:train": "RAG_ARCHIVE_DIR=archive_eval/train RAG_RETRIEVAL=vector tsx server/generateGeneralRagEvaluation.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@langchain/core": "^1.2.1",
    "@langchain/google-genai": "^2.2.0",
    "@langchain/openai": "^1.5.3",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "langchain": "^1.5.2",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.16.0",
    "motion": "^12.23.24",
    "mysql2": "^3.22.5",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
