# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# LangChain agent calls use this key. If it is empty, the API falls back to deterministic local prototype output.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-1.5-flash"

# LLM provider. Use "local" to call a llama.cpp OpenAI-compatible server.
# Example local server:
# llama-server -hf yuxinlu1/gemma-4-12B-agentic-fable5-composer2.5-v2-3.5x-tau2-GGUF:Q4_K_M --host 127.0.0.1 --port 8080 -c 16384
LLM_PROVIDER="local"
LOCAL_LLM_BASE_URL="http://127.0.0.1:8080/v1"
LOCAL_LLM_MODEL="yuxinlu1/gemma-4-12B-agentic-fable5-composer2.5-v2-3.5x-tau2-GGUF:Q4_K_M"
LOCAL_LLM_API_KEY="local"
LOCAL_LLM_CONTEXT_SIZE="16384"
LOCAL_LLM_CHUNK_TOKENS="10000"

# Paid comparison provider. The persona pipeline never calls it unless --provider openai is explicit.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

# Local embedding model for vector RAG.
# Build index: source .venv/bin/activate && npm run rag:index:bge-m3
BGE_M3_PYTHON=".venv/bin/python"
BGE_M3_QUERY_TIMEOUT_MS="120000"
RAG_ARCHIVE_DIR="archive"
RAG_VECTOR_INDEX_DIR="data/vector_index"
RAG_CHUNK_SIZE="1600"
RAG_CHUNK_OVERLAP="220"
RAG_RETRIEVAL_LIMIT="14"

# Optional Cohere reranker for better RAG evidence ordering.
# When enabled, bge-m3 retrieves candidates first and Cohere reranks the top candidates.
RAG_RERANKER=""
COHERE_API_KEY=""
COHERE_RERANK_MODEL="rerank-v3.5"
COHERE_RERANK_CANDIDATE_LIMIT="40"
COHERE_RERANK_MAX_TOKENS_PER_DOC="1200"
COHERE_RERANK_TIMEOUT_MS="20000"
COHERE_RERANK_MIN_INTERVAL_MS="6500"
COHERE_RERANK_RETRY_ON_429="true"
COHERE_RERANK_429_RETRY_DELAY_MS="12000"

# Optional LLM-as-Judge evaluation.
# Uses LLM_PROVIDER / LOCAL_LLM_* or Gemini settings above.
AMY_HOOD_JUDGE_USE_LLM="false"
AMY_HOOD_JUDGE_TEMPERATURE="0"
RAG_EVAL_EVIDENCE_CHAR_LIMIT="8000"
EVENT_MATCHING_MAX_OUTPUT_TOKENS="900"
ACTION_ALIGNMENT_MAX_OUTPUT_TOKENS="700"
ACTION_ALIGNMENT_JUDGE_MAX_OUTPUT_TOKENS="500"
ACTION_ALIGNMENT_EVAL_PATH="evaluation/amy_hood_action_alignment_eval.json"
A_TRACK_COPY_MAX_OUTPUT_TOKENS="500"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MySQL database connection for the API server.
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="password"
MYSQL_DATABASE="decision"

# Sherlock CLI command. Use an absolute path only if the API server cannot find `sherlock`.
SHERLOCK_COMMAND="sherlock"
SHERLOCK_SITE_TIMEOUT_SECONDS="5"
SHERLOCK_PROCESS_TIMEOUT_MS="20000"
SNS_REFERENCE_TARGETS="LinkedIn,X,Threads,Naver Blog,Tistory"
SHERLOCK_TARGET_SITES="LinkedIn,Twitter,threads,Naver"

# Reference persona RAG generation.
REFERENCE_PERSONA_SUBJECT="Amy Hood"
REFERENCE_PERSONA_EVIDENCE_LIMIT="16"
REFERENCE_PERSONA_RAG_QUERY=""

# Optional crawler API key for a later FireCrawl integration.
FIRECRAWL_API_KEY=""
