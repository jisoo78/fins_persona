# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
# LangChain agent calls use this key. If it is empty, the API falls back to deterministic local prototype output.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-1.5-flash"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MySQL database connection for the API server.
MYSQL_HOST="127.0.0.1"
MYSQL_PORT="3306"
MYSQL_USER="root"
MYSQL_PASSWORD="password"
MYSQL_DATABASE="decision"

# Sherlock CLI command. Use an absolute path if the API server cannot find `sherlock`.
SHERLOCK_COMMAND="/Users/choijisoo/.local/bin/sherlock"
SHERLOCK_SITE_TIMEOUT_SECONDS="5"
SHERLOCK_PROCESS_TIMEOUT_MS="20000"

# Optional crawler API key for a later FireCrawl integration.
FIRECRAWL_API_KEY=""
